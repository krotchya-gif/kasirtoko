# ============================================
# KasirToko Environment Configuration
# ============================================

# WAJIB: Flask Secret Key
# Minimal 32 karakter, gunakan random string
# Generate: openssl rand -hex 32
SECRET_KEY=your-secret-key-minimum-32-characters-long

# =========================================================
# DATABASE (Opsional - default menggunakan SQLite)
# =========================================================

# Pilihan 1: PostgreSQL (Recommended untuk production)
# Format: postgresql://username:password@hostname:port/database
# POSTGRES_URL=postgresql://kasirtoko:password@localhost:5432/kasirtoko

# Pilihan 2: SQLite (Default - simple, file-based)
# Tidak perlu setting, otomatis membuat kasirtoko.db

# =========================================================
# FLASK CONFIGURATION
# =========================================================

# Environment: development | production
FLASK_ENV=production

# Debug mode: 0 (false) | 1 (true)
FLASK_DEBUG=0

# =========================================================
# SERVER CONFIGURATION ( untuk Gunicorn )
# =========================================================

# Jumlah worker processes (formula: 2 x CPU cores + 1)
# WORKERS=4

# Timeout dalam detik
# TIMEOUT=120

# =========================================================
# BACKUP CONFIGURATION
# =========================================================

# Direktori backup
BACKUP_DIR=./backups

# Retention backup (hari)
BACKUP_RETENTION_DAYS=30

# =========================================================
# OPTIONAL: Fitur Tambahan
# =========================================================

# WhatsApp API (jika ingin integrasi WA otomatis)
# WHATSAPP_API_KEY=your-api-key

# Email SMTP (jika ingin kirim email)
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# Firebase (untuk push notification)
# FIREBASE_SERVER_KEY=your-firebase-key
